              "actorId": "player",
              "direction": "14",
              "__collapse": true
            },
            "id": "b97dd030-c3d2-44ec-8f31-beddbf7ba55d"
          },
          {
            "command": "EVENT_IF",
            "args": {
              "condition": {
                "type": "eq",
                "valueA": {
                  "type": "variable",
                  "value": "14"
                },
                "valueB": {
                  "type": "constant",
                  "value": "b001-0000-0000-0000-000000000010"
                }
              },
              "__collapseElse": true
            },
            "children": {
