      "command": "EVENT_COMMENT",
      "args": {
        "text": "MOVE NPC RANDOM",
        "__collapse": true
      },
      "id": "comment-0094-0000-0000-0000-000000000000"
    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Pick a random direction (0=down, 1=right, 2=up, 3=left), check metatile collision at the target tile, and move only if collision matches the mask.",
        "__collapse": true
      },
      "id": "comment-0095-0000-0000-0000-000000000000"
    },
