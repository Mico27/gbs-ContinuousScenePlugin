{
  "_resourceType": "script",
  "id": "c468dd94-f2e8-4583-ba29-de77bb527f50",
  "name": "MoveNPCRandom",
  "description": "Moves Actor A one step in a random cardinal direction, but only if the destination metatile's collision value matches CollisionMask (V0). Typically called from an NPC's update script on a timer. After the move attempt, waits 30 frames before returning.",
  "variables": {
    "V0": {
      "id": "V0",
      "name": "CollisionMask",
      "passByReference": false
    }
  },
  "actors": {
    "0": {
      "id": "0",
      "name": "Actor A"
    }
  },
  "symbol": "script_2",
