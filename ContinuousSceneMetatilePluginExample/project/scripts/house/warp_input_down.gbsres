              "direction": "14",
              "__collapse": true
            },
            "id": "fb286d4f-b655-43ed-bd84-d6a5e21d626d"
          },
          {
            "command": "EVENT_IF",
            "args": {
              "condition": {
                "type": "eq",
                "valueA": {
                  "type": "variable",
                  "value": "14"
                },
