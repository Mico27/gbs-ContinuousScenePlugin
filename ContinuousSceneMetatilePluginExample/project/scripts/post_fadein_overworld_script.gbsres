{
  "_resourceType": "script",
  "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
  "name": "Post Fadein Overworld Script",
  "symbol": "script_post_fadein_overworl",
  "description": "Runs after each scene fade-in. Unlocks the script runner, then checks if the player spawned on a door (metatile 124) or cave entrance (metatile 123). If so, steps them 2 tiles south to clear the entrance. Finally resets WarpCooldown (var 20) to 0.",
  "variables": {},
  "actors": {},
  "script": [
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "POST FADEIN OVERWORLD SCRIPT"
      },
      "id": "comment-0055-0000-0000-0000-000000000000"
    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Release script lock so the player regains control."
      },
      "id": "comment-0056-0000-0000-0000-000000000000"
    },
    {
      "command": "EVENT_SCRIPT_UNLOCK",
      "args": {},
      "id": "a1b2c3d4-0001-0000-0000-000000000007"
    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Wait one frame to let the engine settle after fade."
      },
      "id": "comment-0057-0000-0000-0000-000000000000"
    },
    {
      "command": "EVENT_IDLE",
      "args": {},
      "id": "a1b2c3d4-0001-0000-0000-000000000008"
    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Read the player's current tile position into PlayerX (var 12) / PlayerY (var 13)."
      },
      "id": "comment-0058-0000-0000-0000-000000000000"
    },
    {
      "command": "EVENT_ACTOR_GET_POSITION",
      "args": {
