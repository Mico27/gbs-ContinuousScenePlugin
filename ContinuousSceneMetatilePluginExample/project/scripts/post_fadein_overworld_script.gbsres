        "output": "0"
      },
      "id": "a1b2c3d4-0001-0000-0000-000000000002"
    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "If standing on a door (124) or cave entrance (123): step 2 tiles south to clear the entrance."
      },
      "id": "comment-0060-0000-0000-0000-000000000000"
    },
