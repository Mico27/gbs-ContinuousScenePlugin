{
  "_resourceType": "script",
  "id": "f7a1e2d3-4b5c-6d7e-8f9a-0b1c2d3e4f5a",
  "name": "Warp Script",
  "description": "Central warp router. Called by all warp triggers. Guards against re-entry with WarpCooldown (var 20), then routes to the correct destination scene via chained switches on WarpId (V0). Switch 1: warpIds 1-16. Switch 2: warpIds 17-32. Switch 3: warpIds 33-48. Switch 4: warpIds 49-51.",
  "variables": {
    "V0": {
      "id": "V0",
      "name": "WarpId",
      "passByReference": false
    }
  },
  "actors": {},
