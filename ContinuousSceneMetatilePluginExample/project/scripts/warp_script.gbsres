    },
    {
      "command": "EVENT_COMMENT",
      "args": {
        "text": "Guard: skip entire warp if WarpCooldown (var 20) is already 1 (prevents warp loop)."
      },
      "id": "comment-0002-0000-0000-0000-000000000000"
    },
