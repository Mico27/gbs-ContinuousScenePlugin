                    "$variable[V0]$": {
                      "type": "variable",
                      "value": "17"
                    }
                  },
                  "id": "69d1533c-d87d-4639-956e-5291c1f4a4b2"
                }
              ],
              "false": []
            },
            "id": "e88553a7-f76c-4482-889b-50c31340a27a"
          }
        ],
        "false": []
      },
      "id": "1f8342cf-d6d9-4d60-9e73-2a9fa2e3a5f1"
    },
    {
      "command": "EVENT_SET_INPUT_SCRIPT",
      "args": {
