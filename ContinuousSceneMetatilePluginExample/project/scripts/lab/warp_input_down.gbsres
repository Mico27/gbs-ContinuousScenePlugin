          "down"
        ],
        "override": false,
        "__scriptTabs": "press"
      },
      "children": {
        "true": [
          {
            "command": "EVENT_ACTOR_GET_DIRECTION",
            "args": {
              "actorId": "player",
              "direction": "14",
              "__collapse": true
            },
            "id": "83d72b0b-f846-41f0-80d9-eb287545c350"
          },
          {
            "command": "EVENT_IF",
            "args": {
              "condition": {
                "type": "eq",
